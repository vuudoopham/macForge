#!/usr/bin/env bash
#
# macForge - macOS machine bootstrap
# Usage:
#   ./install
#
# Safe to run multiple times.

set -euo pipefail

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIGS_DIR="$DOTFILES_DIR/configs"
SCRIPTS_DIR="$DOTFILES_DIR/scripts"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() {
  echo -e "${BLUE}==>${NC} $1"
}

success() {
  echo -e "${GREEN}✓${NC} $1"
}

warn() {
  echo -e "${YELLOW}!${NC} $1"
}

error() {
  echo -e "${RED}✗${NC} $1" >&2
}

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------
command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# -----------------------------------------------------------------------------
# Step 1: Xcode Command Line Tools
# -----------------------------------------------------------------------------
install_xcode_cli() {
  log "Checking Xcode Command Line Tools..."

  if xcode-select -p &>/dev/null; then
    success "Xcode Command Line Tools already installed"
    return
  fi

  log "Installing Xcode Command Line Tools (this may take a while)..."
  xcode-select --install || true

  # Wait for installation to complete
  until xcode-select -p &>/dev/null; do
    sleep 5
  done
  success "Xcode Command Line Tools installed"
}

# -----------------------------------------------------------------------------
# Step 2: Homebrew
# -----------------------------------------------------------------------------
install_homebrew() {
  log "Checking Homebrew..."

  if command_exists brew; then
    success "Homebrew already installed"
  else
    log "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    success "Homebrew installed"
  fi

  # Ensure brew is in PATH for this session (Apple Silicon + Intel)
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

# -----------------------------------------------------------------------------
# Step 3: Brew bundle (packages from Brewfile)
# -----------------------------------------------------------------------------
install_packages() {
  log "Installing packages from Brewfile..."

  if [[ ! -f "$DOTFILES_DIR/Brewfile" ]]; then
    error "Brewfile not found in $DOTFILES_DIR"
    exit 1
  fi

  brew bundle --file="$DOTFILES_DIR/Brewfile"
  success "Brew packages installed/updated"
}

# -----------------------------------------------------------------------------
# Step 4: Symlink dotfiles / configs
# -----------------------------------------------------------------------------
link_configs() {
  log "Linking configuration files..."

  # zsh
  if [[ -f "$CONFIGS_DIR/zsh/.zshrc" ]]; then
    ln -sf "$CONFIGS_DIR/zsh/.zshrc" "$HOME/.zshrc"
    success "Linked .zshrc"
  fi

  if [[ -f "$CONFIGS_DIR/zsh/.zprofile" ]]; then
    ln -sf "$CONFIGS_DIR/zsh/.zprofile" "$HOME/.zprofile"
    success "Linked .zprofile"
  fi

  if [[ -f "$CONFIGS_DIR/zsh/.p10k.zsh" ]]; then
    ln -sf "$CONFIGS_DIR/zsh/.p10k.zsh" "$HOME/.p10k.zsh"
    success "Linked .p10k.zsh"
  fi

  # git
  if [[ -f "$CONFIGS_DIR/git/.gitconfig" ]]; then
    mkdir -p "$HOME/.config/git" 2>/dev/null || true
    ln -sf "$CONFIGS_DIR/git/.gitconfig" "$HOME/.gitconfig"
    success "Linked .gitconfig"
  fi

  # Add more symlinks here as you add configs (nvim, tmux, etc.)
}

# -----------------------------------------------------------------------------
# Step 4b: Restore editor configs (Cursor / VS Code)
# -----------------------------------------------------------------------------
restore_editor_configs() {
  log "Restoring editor configurations (if present)..."

  # Cursor
  if [[ -f "$CONFIGS_DIR/cursor/User/settings.json" ]]; then
    mkdir -p "$HOME/Library/Application Support/Cursor/User"
    cp -f "$CONFIGS_DIR/cursor/User/settings.json" "$HOME/Library/Application Support/Cursor/User/settings.json"
    success "Restored Cursor settings.json"

    if [[ -f "$CONFIGS_DIR/cursor/User/keybindings.json" ]]; then
      cp -f "$CONFIGS_DIR/cursor/User/keybindings.json" "$HOME/Library/Application Support/Cursor/User/keybindings.json"
    fi

    if [[ -f "$CONFIGS_DIR/cursor/User/extensions.txt" ]]; then
      warn "Cursor extensions listed in configs/cursor/User/extensions.txt"
      warn "After install, run:  xargs -n1 cursor --install-extension < configs/cursor/User/extensions.txt"
    fi
  fi

  # VS Code
  if [[ -f "$CONFIGS_DIR/vscode/User/settings.json" ]]; then
    mkdir -p "$HOME/Library/Application Support/Code/User"
    cp -f "$CONFIGS_DIR/vscode/User/settings.json" "$HOME/Library/Application Support/Code/User/settings.json"
    success "Restored VS Code settings.json"

    if [[ -f "$CONFIGS_DIR/vscode/User/keybindings.json" ]]; then
      cp -f "$CONFIGS_DIR/vscode/User/keybindings.json" "$HOME/Library/Application Support/Code/User/keybindings.json"
    fi

    if [[ -f "$CONFIGS_DIR/vscode/User/extensions.txt" ]]; then
      warn "VS Code extensions listed in configs/vscode/User/extensions.txt"
      warn "After install, run:  xargs -n1 code --install-extension < configs/vscode/User/extensions.txt"
    fi
  fi
}

# -----------------------------------------------------------------------------
# Step 5: macOS system defaults
# -----------------------------------------------------------------------------
apply_macos_defaults() {
  if [[ -f "$SCRIPTS_DIR/macos-defaults.sh" ]]; then
    log "Applying macOS system defaults..."
    bash "$SCRIPTS_DIR/macos-defaults.sh"
    success "macOS defaults applied"
  else
    warn "No macos-defaults.sh found — skipping system defaults"
  fi
}

# -----------------------------------------------------------------------------
# Step 6: Post-install notes
# -----------------------------------------------------------------------------
post_install_notes() {
  echo
  log "Setup complete!"
  echo
  echo "Next steps / manual items (common):"
  echo "  • Restart iTerm2 / your terminal so new shell config loads"
  echo "  • Log into: Tailscale, ExpressVPN, LastPass, Microsoft 365, Slack, Discord, WhatsApp"
  echo "  • Activate licenses for: Moom, Parallels, CrossOver, CleanMyMac (if using paid versions)"
  echo "  • Sign into Battle.net / Steam and install games if desired"
  echo "  • Configure UHK (Ultimate Hacking Keyboard) via the UHK Agent"
  echo "  • Set up AlDente battery limits"
  echo "  • Review Cursor / VS Code settings and extensions (restored if present in configs/)"
  echo "  • Review and tweak macOS settings as desired"
  echo
  echo "To re-run safely in the future:"
  echo "  cd ~/macForge && ./install"
  echo
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

main() {
  echo
  echo "macForge (legacy ./install wrapper) — setting up your Mac"
  echo "========================================================="
  echo "Delegating to the new ./macForge tool for machine 'personal'..."
  echo

  exec "$SCRIPT_DIR/macForge" apply --machine personal "$@"
}

main "$@"
